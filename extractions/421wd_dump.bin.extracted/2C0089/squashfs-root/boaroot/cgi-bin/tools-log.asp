                }});
            }
            function doDownload()
            {
            	 $('#apply-noti-background').show();
                requestType = 'download';
                $.ajax({url: "/cgi-bin/syslog_tool.cgi?requesttype=" + requestType + "&TokenString="+tokenString, method: 'GET', complete: function(res){
                    var filePath = res.responseText;
                    location.assign(filePath);
                    doDeleteData();
                }});
                setTimeout(function(){$('#apply-noti-background').hide();}, 8000);
            }
            function doRefresh()
            {
            	 $('#apply-noti-background').show();
                loadLogFile();
                setTimeout(function(){$('#apply-noti-background').hide();}, 2000);
            }
            var resource;
            function loadLogFile()
            {
                requestType = 'refresh';
                tokenString = document.getElementById("Token").value;
                $.ajax({url: "/cgi-bin/syslog_tool.cgi?requesttype=" + requestType + "&logtype="+ logtype +  "&TokenString="+tokenString, method: 'GET', complete: function(res){
                    loadLog();
                }});
            }
			function loadLog()
			{
				 $.ajax({url: "/messages.log", method: 'GET', complete: function(res){
                    document.getElementById("logFrame").innerHTML = res.responseText;
                }})
			}
			function change_log_type(new_type) {
				logtype = new_type;
				for (var i =0 ; i < 3; i++) {
					if (i != new_type) {
						$("#lt" + i).addClass("tab-disabled");
					}
					else {
						$("#lt" + i).removeClass("tab-disabled");
					}
				}
				doRefresh();
			}
